<?xml version="1.0" ?>
<robot name="kuka_kr10" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- KUKA KR-10 R1100-2 Robot URDF -->
  <!-- Generated from DH parameters -->

  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 1 (Base) -->
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.4"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.08" length="0.4"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 2 -->
  <link name="link2">
    <inertial>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <mass value="4.0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.02"/>
    </inertial>
    <visual>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.6"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0.3 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.6"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 3 -->
  <link name="link3">
    <inertial>
      <origin xyz="0.28 0 0" rpy="0 0 0"/>
      <mass value="3.5"/>
      <inertia ixx="0.04" ixy="0.0" ixz="0.0" iyy="0.04" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0.28 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.56"/>
      </geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0.28 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.07" length="0.56"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 4 (Wrist Base) -->
  <link name="link4">
    <inertial>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <mass value="2.0"/>
      <inertia ixx="0.02" ixy="0.0" ixz="0.0" iyy="0.02" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.06"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 5 (Wrist) -->
  <link name="link5">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.2"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="gray"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Link 6 (End Effector Flange) -->
  <link name="link6">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.02"/>
      </geometry>
    </collision>
  </link>

  <!-- End Effector Tool Frame -->
  <link name="tool0"/>

  <!-- ==================== JOINTS ==================== -->

  <!-- Joint 1: Base to Link1 (Rotation about Z) -->
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9671" upper="2.9671" effort="300" velocity="2.0944"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- Joint 2: Link1 to Link2 (Rotation about Y) -->
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.4" rpy="-1.5708 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.316" upper="0.7854" effort="300" velocity="2.0944"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- Joint 3: Link2 to Link3 (Rotation about Y) -->
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0.56 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.7227" effort="250" velocity="2.0944"/>
    <dynamics damping="0.1" friction="0.01"/>
  </joint>

  <!-- Joint 4: Link3 to Link4 (Rotation about X) -->
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0.56 0 0.515" rpy="-1.5708 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.2289" upper="3.2289" effort="100" velocity="3.1416"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <!-- Joint 5: Link4 to Link5 (Rotation about Y) -->
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.2" rpy="1.5708 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0944" upper="2.0944" effort="100" velocity="3.1416"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <!-- Joint 6: Link5 to Link6 (Rotation about Z) -->
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.1088" upper="6.1088" effort="50" velocity="3.1416"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <!-- Tool Flange -->
  <joint name="tool_joint" type="fixed">
    <parent link="link6"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.09" rpy="0 0 0"/>
  </joint>

  <!-- ==================== MATERIALS ==================== -->
  <material name="orange">
    <color rgba="1.0 0.647 0.0 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="silver">
    <color rgba="0.753 0.753 0.753 1.0"/>
  </material>
</robot>
